# Optional server-side fallback keys. The app primarily reads keys from the
# browser (localStorage) and forwards them per-request to /api/proxy.
# These env vars are ONLY used as a dev convenience fallback and are never
# required. NEVER commit a real .env.local.
#
# DEEPSEEK_API_KEY=sk-xxxx
# OPENAI_API_KEY=sk-xxxx
# DOUBAO_API_KEY=xxxx
